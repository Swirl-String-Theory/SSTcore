# Resource tree at repo root (see setup.py: junction SSTcore/resources -> ../resources for wheels)
graft resources

# Native extension sources (required for sdist → wheel; must match setup.py src_files + bindings)
recursive-include src *.cpp
recursive-include src *.h
recursive-include src *.hpp
recursive-include include *.h

# Include all .fseries knot data files
recursive-include src/knot_fseries *.fseries
recursive-include src/knot_fseries *.short

# Include README and documentation
include Readme.md
include README_sstbindings.txt
include LICENSE

# Include setup files
include setup.py
include pyproject.toml
include MANIFEST.in
include sstcore.py
include sstbindings.py
include swirl_string_core.py

# Include CMake files (for reference, though not used in pip build)
recursive-include cmake *.cmake

recursive-include SSTcore *.py

