# Build artifacts (keep packaged WASM + prebuilds via negations below)
build/
build_node/
*.pyd
**/*.pyd
*.so
*.dylib
*.dll
*.js.map
*.whl
**/*.whl
prebuilds/**/*.pdb

# Allow shipping compiled addon + WASM listed in package.json "files"
!dist/
!dist/**
dist/**/*.whl
!prebuilds/
!prebuilds/**/*.node

# CMake / MSVC debris
CMakeCache.txt
cmake_install.cmake
CMakeFiles/
*.vcxproj
*.vcxproj.filters
*.sln
*.slnx
*.obj
*.lib
*.exp
*.ilk
*.pdb

# Python package tree + bindings (never ship in npm)
src/SSTcore/
src/SSTcore/**
**/SSTcore.egg-info/**
**/*_py.cpp
src/*_py.cpp
src/**/*_py.cpp
src/module_sst.cpp
extern/
setup.py
pyproject.toml

# Large / non-embed resources (keep .fseries + small ideal txt for CMake embed)
resources/knotplot/**
resources/ideal_12_data/**
resources/Results/**
resources/**/*.zip
**/*.stl
resources/*.csv
resources/fseries_batch_results.csv
resources/ideal_11a.txt
resources/ideal_11n.txt
resources/idealLinks_10a.txt
resources/idealLinks_10n.txt

# IDE / OS
.vscode/
.idea/
*.iml
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Tests except smoke entry used by npm test
tests/**
!tests/test_basic.js
examples/
node_examples/
*.test.js
*.spec.js

# Docs: keep build docs listed in package.json files
*.md
!README.md
!NODE_BUILD.md
!LICENSE

# Git / Node
.git/
.gitignore
.node/
node_modules/
.npm/

# Logs / temp
*.log
npm-debug.log*
output/
nul
empty.synctex.gz
SST_Dashboard/
