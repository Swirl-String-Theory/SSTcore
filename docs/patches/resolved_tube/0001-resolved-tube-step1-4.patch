+void bind_resolved_tube_geometry(py::module_& m) {
+    py::class_<sst::SegmentPair>(m, "SegmentPair")
+        .def(py::init<>())
+        .def_readwrite("i", &sst::SegmentPair::i)
+        .def_readwrite("j", &sst::SegmentPair::j)
