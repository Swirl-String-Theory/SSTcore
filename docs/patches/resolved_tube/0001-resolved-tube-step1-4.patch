+        .def_readwrite("minrad_plus", &sst::KinkRecord::minrad_plus)
+        .def_readwrite("minrad", &sst::KinkRecord::minrad)
+        .def_readwrite("turning_angle", &sst::KinkRecord::turning_angle);
