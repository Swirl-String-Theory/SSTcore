*.pyd
*.zip

# Python packaging artifacts
/dist/
/*.egg-info/
/python_build/
/build/temp/
/build/lib/
*.egg
/Secrets.md
/.github/job-logs.txt

# CMake/setuptools generated embed API header (stable path under include/)
/include/generated/

# Build-time junction to repo-root resources (created by setup.py for package_data)
/SSTcore/resources/
/src/SSTcore/resources/