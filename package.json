{
  "name": "SSTcore",
  "version": "0.2.0",
  "description": "SSTcore - Swirl String Theory Canonical Core. High-performance C++ library for knot dynamics, vortex systems, and fluid mechanics (Node native addon + optional WASM). Same project as pip install SSTcore.",
  "main": "index.js",
  "module": "index.js",
  "browser": "dist/swirl_string_core_wasm.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "dist/",
    "binding.gyp",
    "CMakeLists.txt",
    "cmake/",
    "src/",
    "src_bindings/",
    "extern/",
    "include/",
    "docs/",
    "node_examples/",
    "scripts/ensure_knot_embedded.js",
    "scripts/run_node_examples.js",
    "scripts/preflight_wheel_check.py"
  ],
  "scripts": {
    "build": "npm run build:node",
    "build:node": "node scripts/ensure_knot_embedded.js && node scripts/build_node_target.js && node-gyp rebuild",
    "build:wasm": "node scripts/build_wasm.js",
    "build:all": "npm run build:node && npm run build:wasm",
    "install": "node scripts/prebuild.js || node-gyp rebuild || echo 'Native build failed, using WASM fallback'",
    "prepublishOnly": "npm run build:all",
    "test": "node tests/test_basic.js || echo 'Tests not available'",
    "example:biot": "tsx node_examples/biot_savart.example.ts",
    "example:fluid": "tsx node_examples/fluid_dynamics.example.ts",
    "example:frenet": "tsx node_examples/frenet_helicity.example.ts",
    "examples:node:all": "node scripts/run_node_examples.js",
    "wheel:preflight:deps": "python -m pip install --upgrade pip && python -m pip install \"setuptools>=69\" build wheel pybind11 numpy",
    "wheel:preflight:build": "python -m build --wheel --no-isolation -v",
    "wheel:preflight:check": "python scripts/preflight_wheel_check.py",
    "wheel:preflight": "npm run wheel:preflight:deps && npm run wheel:preflight:build && npm run wheel:preflight:check"
  },
  "keywords": [
    "SSTcore",
    "sstcore",
    "swirl-string-theory",
    "physics",
    "fluid-dynamics",
    "knot-theory",
    "vortex",
    "computational-physics",
    "cpp",
    "wasm",
    "angular"
  ],
  "author": "Omar Iskandarani <info@omariskandarani.com>",
  "license": "CC-BY-NC-4.0",
  "homepage": "https://github.com/Swirl-String-Theory/SSTcore#readme",
  "bugs": {
    "url": "https://github.com/Swirl-String-Theory/SSTcore/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Swirl-String-Theory/SSTcore.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "dependencies": {
    "node-addon-api": "^7.0.0"
  },
  "devDependencies": {
    "node-gyp": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0"
  },
  "gypfile": true
}